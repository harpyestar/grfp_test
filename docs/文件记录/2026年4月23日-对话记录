def run(playwright: Playwright) -> None:
    browser = playwright.chromium.launch(headless=False)
    context = browser.new_context()
    page.get_by_role("button", name="RFP Management").click()
    page.get_by_text("Create new RFP project").click()
    page.get_by_label("Organization Name").click()
    page.get_by_label("Organization Name").fill("hyg测试机构")
    page.get_by_text("hyg测试机构(170)").click()
    page.get_by_label("Project name").click()
    page.get_by_label("Project name").fill("AI-testdf")
    page.get_by_label("Contact Person").click()
    page.get_by_placeholder("Area Code").click()
    page.get_by_role("textbox", name="Please enter").click()
    page.get_by_label("Method of Signing").locator("span").nth(1).click()
    page.get_by_text("Manual Notification").click()
    page.get_by_label("Bidding Date Range").get_by_placeholder("Start Time").click()
    page.get_by_role("gridcell", name="1", exact=True).first.click()
    page.get_by_role("gridcell", name="28").nth(2).click()

    # ---------------------
    context.close()
    browser.close()

